# =============================================================================
# Backend Express (Railway / Render / Docker) — server/.env
# =============================================================================

PORT=3001
NODE_ENV=production

# AI
GOOGLE_API_KEY=

# Supabase (service role — tylko backend!)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Adminzy API (koszty globalne itd.) — UUID i/lub emaile, przecinek
# Alternatywa: app_metadata.role=admin lub is_admin=true w Supabase
ADMIN_USER_IDS=
ADMIN_EMAILS=

# Podpis OAuth state (HMAC) — WYMAGANY w production (bez fallbacku)
OAUTH_STATE_SECRET=

# CORS — URL frontendu na Vercel (przecinek dla wielu domen)
ALLOWED_ORIGINS=http://localhost:3000,https://twoja-aplikacja.vercel.app
FRONTEND_URL=https://twoja-aplikacja.vercel.app

# Publiczny URL tego serwisu — OAuth redirect URI generowane automatycznie jeśli poniższe puste
PUBLIC_BACKEND_URL=https://twoj-backend.up.railway.app

# OAuth redirect URI — opcjonalne (nadpisują auto z PUBLIC_BACKEND_URL)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://twoj-backend.up.railway.app/api/social/callback/linkedin

TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_CALLBACK_URL=https://twoj-backend.up.railway.app/api/social/callback/twitter

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://twoj-backend.up.railway.app/api/social/callback/facebook

# Instagram — ta sama aplikacja Meta co Facebook, osobny callback
INSTAGRAM_REDIRECT_URI=https://twoj-backend.up.railway.app/api/social/callback/instagram

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://twoj-backend.up.railway.app/api/social/callback/tiktok

# Opcjonalne — wideo / obrazy
OPENAI_API_KEY=
LUMA_API_KEY=
REPLICATE_API_TOKEN=

# Stripe — test: sk_test_… / LIVE: sk_live_…
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# LIVE setup: npm run stripe:bootstrap:live  →  npm run stripe:live-check
STRIPE_CREATOR_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
STRIPE_CREATOR_YEARLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_BUSINESS_YEARLY_PRICE_ID=
STRIPE_AGENCY_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=
STRIPE_CREDITS_SMALL_PRICE_ID=
STRIPE_CREDITS_MEDIUM_PRICE_ID=
STRIPE_CREDITS_LARGE_PRICE_ID=
STRIPE_CREDITS_MEGA_PRICE_ID=

# Email — Resend (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=noreply@generatorpostow.ai
EMAIL_FROM_NAME=Generator Postów AI
FRONTEND_URL=https://twoja-aplikacja.vercel.app

# Cron — wymagany do POST /api/email/abandoned-checkout (x-cron-key)
CRON_SECRET=

# Tylko dev — wyłącza limity kredytów (NIE ustawiaj na produkcji)
# DISABLE_CREDIT_LIMITS=true
