{
  "version": 2,
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/build-id.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "https://generator-postow-api-production.up.railway.app/health"
    },
    {
      "source": "/api/:path*",
      "destination": "https://generator-postow-api-production.up.railway.app/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://generator-postow-api-production.up.railway.app/health"
    },
    {
      "source": "/((?!api/|assets/|favicon\\.svg|.*\\.[a-zA-Z0-9]+$).*)",
      "destination": "/index.html"
    }
  ]
}
