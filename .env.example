# =============================================================================
# Frontend (Vercel) — zmienne w panelu Vercel → Settings → Environment Variables
# =============================================================================

# --- Deploy ---
# Frontend: Vercel | Backend: Railway (root Dockerfile + railway.toml)
#
# Vercel → Settings → Environment Variables:
#   BACKEND_URL = https://twoj-backend.up.railway.app   (wymagane — proxy api/*)
#
# Railway → Variables: patrz server/.env.example

# URL wdrożonego backendu Express — proxy Vercel (api/[...path].ts)
BACKEND_URL=

# Publiczny URL backendu (OAuth redirect: {PUBLIC_BACKEND_URL}/api/social/callback/{platform})
PUBLIC_BACKEND_URL=

# Supabase (publiczne — trafiają do bundla frontendu)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Opcjonalnie: bezpośredni URL API zamiast relative /api (zwykle zostaw puste na Vercel)
VITE_API_BASE_URL=

# Lokalny dev — port backendu gdy 3001 jest zajęty (proxy Vite: /api → localhost:PORT)
# VITE_DEV_BACKEND_PORT=3002

# Opcjonalnie: bezpośredni backend dla długich jobów (wideo) — omija timeout proxy Vercel
# Np. ten sam URL co BACKEND_URL / PUBLIC_BACKEND_URL
VITE_LONG_RUNNING_API_BASE_URL=

# Stripe LIVE (produkcja) — pk_live_ w Vercel, sk_live_ w Railway
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Sentry (opcjonalnie) — https://sentry.io
VITE_SENTRY_DSN=

# PostHog Analytics (opcjonalnie) — https://posthog.com
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
