# =============================================================================
# Frontend (Vercel) — zmienne w panelu Vercel → Settings → Environment Variables
# =============================================================================

# URL wdrożonego backendu Express (Railway / Render / Fly.io)
# Używane przez proxy Vercel (api/*) — WYMAGANE na produkcji
BACKEND_URL=

# Publiczny URL backendu (Railway: ustaw = wygenerowana domena)
# OAuth redirect URI budowane automatycznie: {PUBLIC_BACKEND_URL}/api/social/callback/{platform}
PUBLIC_BACKEND_URL=

# Supabase (publiczne — trafiają do bundla frontendu)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Opcjonalnie: bezpośredni URL API zamiast proxy Vercel (np. dla długich operacji wideo)
# Jeśli puste, frontend używa relative /api/* (proxy przez Vercel)
VITE_API_BASE_URL=

# Stripe LIVE (produkcja) — pk_live_ w Vercel, sk_live_ w Railway
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Sentry (opcjonalnie) — https://sentry.io
VITE_SENTRY_DSN=

# PostHog Analytics (opcjonalnie) — https://posthog.com
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
